// Sidebar component
const Sidebar = ({ view, onView }) => {
  const items = [
    { k: "dashboard", l: "All schemes", icon: "Folder", count: window.SCHEMES.length },
    { k: "design", l: "In design", icon: "Doc", count: window.SCHEMES.filter(s=>s.status==="design").length },
    { k: "review", l: "In review", icon: "Clock", count: window.SCHEMES.filter(s=>s.status==="review").length },
    { k: "works", l: "On site", icon: "Cog", count: window.SCHEMES.filter(s=>s.status==="works").length },
  ];
  return (
    <aside className="sidebar">
      <div className="brand">
        <div className="brand-mark">R</div>
        <div>
          <div className="brand-name">RMP Design Studio</div>
          <div className="brand-sub">v0.4 · Pilot</div>
        </div>
      </div>
      <div className="nav-group-label">Workspace</div>
      {items.map(it => (
        <div key={it.k} className={"nav-item " + (view === it.k ? "active" : "")} onClick={() => onView(it.k)}>
          <Icon.Folder /> <span>{it.l}</span> <span className="count">{it.count}</span>
        </div>
      ))}
      <div className="nav-group-label">Library</div>
      <div className="nav-item"><Icon.Doc /> Templates <span className="count">5</span></div>
      <div className="nav-item"><Icon.Users /> Ward councillors <span className="count">29</span></div>
      <div className="nav-item"><Icon.Map /> Utility portals <span className="count">9</span></div>
      <div className="nav-item"><Icon.Cog /> Settings</div>
      <div className="sidebar-foot">
        <div className="avatar">JM</div>
        <div className="user-meta">
          Jake McAllister<br/><small>RMP · Design</small>
        </div>
      </div>
    </aside>
  );
};

window.Sidebar = Sidebar;
