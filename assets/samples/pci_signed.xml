/* RMP Design Studio — engineering/technical municipal tool */
:root {
  --bg: oklch(0.985 0.003 85);
  --bg-elev: oklch(0.995 0.002 85);
  --bg-sunken: oklch(0.965 0.005 85);
  --ink: oklch(0.22 0.01 60);
  --ink-2: oklch(0.42 0.01 60);
  --ink-3: oklch(0.62 0.01 60);
  --line: oklch(0.9 0.004 80);
  --line-strong: oklch(0.82 0.005 80);
  --accent: oklch(0.62 0.16 45);      /* hazard orange */
  --accent-ink: oklch(0.32 0.12 45);
  --accent-wash: oklch(0.96 0.03 45);
  --slate: oklch(0.52 0.04 240);      /* status blue-slate */
  --slate-wash: oklch(0.96 0.015 240);
  --green: oklch(0.58 0.1 150);
  --green-wash: oklch(0.96 0.03 150);
  --amber: oklch(0.72 0.14 75);
  --amber-wash: oklch(0.96 0.04 75);
  --red: oklch(0.56 0.16 25);
  --red-wash: oklch(0.96 0.03 25);
  --radius: 6px;
  --radius-sm: 4px;
  --shadow-sm: 0 1px 0 oklch(0 0 0 / 0.04);
  --shadow: 0 1px 2px oklch(0 0 0 / 0.05), 0 4px 12px oklch(0 0 0 / 0.04);
  --shadow-lg: 0 8px 28px oklch(0 0 0 / 0.12), 0 2px 4px oklch(0 0 0 / 0.06);
  --font-sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  --font-mono: "JetBrains Mono", ui-monospace, "SF Mono", Menlo, monospace;
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }
body {
  font-family: var(--font-sans);
  color: var(--ink);
  background: var(--bg);
  font-size: 14px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  font-feature-settings: "cv02", "cv03", "cv04", "cv11", "ss01";
}

.mono { font-family: var(--font-mono); font-feature-settings: "zero"; letter-spacing: -0.01em; }

/* Layout */
.app {
  display: grid;
  grid-template-columns: 220px 1fr;
  min-height: 100vh;
}

.sidebar {
  border-right: 1px solid var(--line);
  background: var(--bg-elev);
  padding: 20px 14px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  position: sticky;
  top: 0;
  height: 100vh;
}

.brand {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 4px 8px 20px;
  border-bottom: 1px solid var(--line);
  margin-bottom: 14px;
}
.brand-mark {
  width: 28px; height: 28px;
  background: var(--ink);
  border-radius: 4px;
  display: grid; place-items: center;
  color: var(--bg);
  font-family: var(--font-mono);
  font-weight: 700;
  font-size: 11px;
  letter-spacing: -0.02em;
}
.brand-name {
  font-weight: 600;
  font-size: 13px;
  letter-spacing: -0.01em;
}
.brand-sub {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--ink-3);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.nav-group-label {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--ink-3);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 16px 8px 6px;
}
.nav-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 7px 8px;
  border-radius: var(--radius-sm);
  color: var(--ink-2);
  cursor: pointer;
  font-size: 13px;
  user-select: none;
}
.nav-item:hover { background: var(--bg-sunken); color: var(--ink); }
.nav-item.active { background: var(--ink); color: var(--bg); }
.nav-item .count {
  margin-left: auto;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-3);
}
.nav-item.active .count { color: oklch(0.85 0.003 85); }

.sidebar-foot {
  margin-top: auto;
  padding: 12px 8px;
  border-top: 1px solid var(--line);
  display: flex; align-items: center; gap: 10px;
}
.avatar {
  width: 28px; height: 28px;
  border-radius: 50%;
  background: var(--accent-wash);
  color: var(--accent-ink);
  display: grid; place-items: center;
  font-weight: 600;
  font-size: 11px;
}
.user-meta { font-size: 12px; line-height: 1.2; }
.user-meta small { color: var(--ink-3); font-size: 10px; font-family: var(--font-mono); }

/* Main */
.main {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.topbar {
  height: 56px;
  border-bottom: 1px solid var(--line);
  padding: 0 28px;
  display: flex;
  align-items: center;
  gap: 16px;
  background: var(--bg-elev);
  position: sticky; top: 0; z-index: 10;
}
.crumbs {
  display: flex; align-items: center; gap: 8px;
  font-size: 13px; color: var(--ink-2);
}
.crumbs .sep { color: var(--ink-3); }
.crumbs .current { color: var(--ink); font-weight: 500; }

.searchbar {
  margin-left: auto;
  position: relative;
  width: 280px;
}
.searchbar input {
  width: 100%;
  height: 32px;
  padding: 0 12px 0 32px;
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  background: var(--bg);
  font: inherit;
  color: var(--ink);
}
.searchbar input:focus { outline: 2px solid var(--accent-wash); border-color: var(--accent); }
.searchbar svg { position: absolute; left: 10px; top: 8px; color: var(--ink-3); }

.content { padding: 28px 28px 60px; max-width: 1360px; width: 100%; }

/* Page header */
.page-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20px;
  margin-bottom: 22px;
}
.page-title {
  font-size: 24px;
  font-weight: 600;
  letter-spacing: -0.02em;
  margin: 0 0 4px;
}
.page-sub {
  color: var(--ink-2);
  font-size: 13px;
  margin: 0;
}

/* Buttons */
.btn {
  height: 34px;
  padding: 0 14px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--line-strong);
  background: var(--bg-elev);
  color: var(--ink);
  font: inherit;
  font-weight: 500;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  white-space: nowrap;
}
.btn:hover { background: var(--bg-sunken); }
.btn.primary {
  background: var(--ink);
  color: var(--bg);
  border-color: var(--ink);
}
.btn.primary:hover { background: oklch(0.12 0.01 60); }
.btn.accent {
  background: var(--accent);
  color: white;
  border-color: var(--accent);
}
.btn.accent:hover { background: oklch(0.56 0.17 45); }
.btn.ghost {
  background: transparent;
  border-color: transparent;
  color: var(--ink-2);
}
.btn.ghost:hover { background: var(--bg-sunken); color: var(--ink); }
.btn.sm { height: 28px; padding: 0 10px; font-size: 12px; }
.btn .kbd {
  font-family: var(--font-mono);
  font-size: 10px;
  padding: 1px 5px;
  border-radius: 3px;
  background: oklch(0 0 0 / 0.08);
  color: var(--ink-3);
  margin-left: 6px;
}
.btn.primary .kbd { background: oklch(1 0 0 / 0.12); color: oklch(1 0 0 / 0.7); }

/* Stat strip */
.stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: var(--bg-elev);
  margin-bottom: 22px;
  overflow: hidden;
}
.stat {
  padding: 14px 18px;
  border-right: 1px solid var(--line);
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.stat:last-child { border-right: 0; }
.stat-label {
  font-family: var(--font-mono);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--ink-3);
}
.stat-value {
  font-size: 22px;
  font-weight: 600;
  letter-spacing: -0.02em;
  font-feature-settings: "tnum";
}
.stat-value .unit { font-size: 13px; color: var(--ink-3); font-weight: 400; margin-left: 4px; }
.stat-meta {
  font-size: 11px;
  color: var(--ink-3);
  font-family: var(--font-mono);
}
.stat-meta .up { color: var(--green); }
.stat-meta .down { color: var(--red); }

/* Filters */
.filters {
  display: flex;
  gap: 8px;
  margin-bottom: 14px;
  align-items: center;
}
.chip {
  height: 28px;
  padding: 0 12px;
  border: 1px solid var(--line);
  border-radius: 14px;
  background: var(--bg-elev);
  font-size: 12px;
  color: var(--ink-2);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.chip.active {
  background: var(--ink);
  color: var(--bg);
  border-color: var(--ink);
}
.chip .count {
  font-family: var(--font-mono);
  font-size: 10px;
  opacity: 0.6;
}

/* Table */
.table-wrap {
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: var(--bg-elev);
  overflow: hidden;
}
table.schemes {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}
table.schemes th {
  text-align: left;
  font-family: var(--font-mono);
  font-weight: 500;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--ink-3);
  padding: 10px 14px;
  border-bottom: 1px solid var(--line);
  background: var(--bg-sunken);
}
table.schemes td {
  padding: 14px;
  border-bottom: 1px solid var(--line);
  vertical-align: middle;
}
table.schemes tr:last-child td { border-bottom: 0; }
table.schemes tbody tr { cursor: pointer; }
table.schemes tbody tr:hover { background: var(--bg-sunken); }
.row-ref { font-family: var(--font-mono); font-size: 12px; color: var(--ink-2); }
.row-name { font-weight: 500; color: var(--ink); }
.row-sub { font-size: 11px; color: var(--ink-3); margin-top: 2px; font-family: var(--font-mono); }

/* Status pill */
.pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 11px;
  font-weight: 500;
  font-family: var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  border: 1px solid transparent;
}
.pill::before {
  content: "";
  width: 6px; height: 6px;
  border-radius: 50%;
  background: currentColor;
}
.pill.design { background: var(--slate-wash); color: var(--slate); }
.pill.ready { background: var(--green-wash); color: var(--green); }
.pill.works { background: var(--accent-wash); color: var(--accent-ink); }
.pill.review { background: var(--amber-wash); color: oklch(0.5 0.14 75); }
.pill.archived { background: var(--bg-sunken); color: var(--ink-3); }

/* Pack progress bar */
.pack-bar { display: flex; align-items: center; gap: 8px; }
.pack-bar-track {
  flex: 1;
  height: 6px;
  background: var(--bg-sunken);
  border-radius: 3px;
  overflow: hidden;
  min-width: 80px;
  max-width: 120px;
}
.pack-bar-fill {
  height: 100%;
  background: var(--ink);
  border-radius: 3px;
  transition: width 0.3s ease;
}
.pack-bar-fill.full { background: var(--green); }
.pack-bar-count {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-3);
  min-width: 32px;
}

/* Scheme detail */
.tabs {
  display: flex;
  gap: 2px;
  border-bottom: 1px solid var(--line);
  margin-bottom: 24px;
}
.tab {
  padding: 10px 14px;
  font-size: 13px;
  color: var(--ink-2);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.tab:hover { color: var(--ink); }
.tab.active { color: var(--ink); border-bottom-color: var(--ink); font-weight: 500; }
.tab .badge {
  font-family: var(--font-mono);
  font-size: 10px;
  background: var(--bg-sunken);
  color: var(--ink-3);
  padding: 1px 6px;
  border-radius: 8px;
}
.tab.active .badge { background: var(--ink); color: var(--bg); }

/* Form sections */
.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}
.form-section {
  background: var(--bg-elev);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  padding: 20px;
}
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--line);
}
.section-title {
  font-size: 13px;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 8px;
}
.section-num {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--ink-3);
  background: var(--bg-sunken);
  padding: 2px 6px;
  border-radius: 3px;
}

.field {
  margin-bottom: 12px;
}
.field label {
  display: block;
  font-size: 11px;
  color: var(--ink-3);
  font-family: var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 4px;
}
.field .val {
  font-size: 13px;
  color: var(--ink);
  padding: 8px 10px;
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  background: var(--bg);
  min-height: 34px;
  display: flex;
  align-items: center;
}
.field input, .field select, .field textarea {
  width: 100%;
  font: inherit;
  font-size: 13px;
  padding: 8px 10px;
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  background: var(--bg);
  color: var(--ink);
  transition: border-color 0.15s, box-shadow 0.15s;
}
.field input:focus, .field select:focus, .field textarea:focus {
  outline: none;
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-wash);
}
.field.mono input, .field input.mono { font-family: var(--font-mono); }

.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.field-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }

/* Ward picker */
.ward-picker {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  margin-bottom: 16px;
}
.ward-btn {
  padding: 10px 12px;
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  background: var(--bg);
  text-align: left;
  cursor: pointer;
  font: inherit;
  font-size: 12px;
  color: var(--ink-2);
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.ward-btn:hover { border-color: var(--line-strong); }
.ward-btn.active {
  border-color: var(--ink);
  background: var(--ink);
  color: var(--bg);
}
.ward-btn .ward-num {
  font-family: var(--font-mono);
  font-size: 10px;
  opacity: 0.6;
}
.ward-btn .ward-name { font-weight: 500; }

.copy-list {
  background: var(--bg);
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  padding: 14px 18px;
  font-size: 13px;
  line-height: 1.8;
}
.copy-list .entry {
  display: flex;
  align-items: center;
  gap: 10px;
}
.copy-list .entry::before {
  content: "•";
  color: var(--ink-3);
}
.copy-list .entry.ward-entry::before { color: var(--accent); }
.copy-list .entry .role { color: var(--ink-2); }
.copy-list .entry .name { color: var(--ink); font-weight: 500; }
.copy-list .entry.ward-entry .name { color: var(--accent-ink); }

/* Pack preview */
.pack-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.doc-card {
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: var(--bg-elev);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.doc-preview {
  aspect-ratio: 1 / 1.2;
  background: var(--bg-sunken);
  position: relative;
  border-bottom: 1px solid var(--line);
  padding: 16px;
  overflow: hidden;
}
.doc-preview .sheet {
  background: white;
  width: 100%;
  height: 100%;
  box-shadow: 0 2px 6px oklch(0 0 0 / 0.08);
  padding: 8px;
  font-size: 5px;
  line-height: 1.3;
  color: #333;
  overflow: hidden;
  transform: scale(1);
  transform-origin: top left;
}
.doc-info {
  padding: 14px 16px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.doc-name { font-weight: 500; font-size: 13px; }
.doc-meta {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--ink-3);
  display: flex;
  justify-content: space-between;
}
.doc-status {
  padding: 10px 16px;
  border-top: 1px solid var(--line);
  display: flex;
  gap: 8px;
  align-items: center;
  background: var(--bg-sunken);
}

/* Modal */
.modal-backdrop {
  position: fixed; inset: 0;
  background: oklch(0.2 0.01 60 / 0.4);
  display: grid; place-items: center;
  z-index: 100;
  padding: 40px;
  animation: fadein 0.15s ease;
}
@keyframes fadein { from { opacity: 0; } to { opacity: 1; } }
.modal {
  background: var(--bg-elev);
  border-radius: var(--radius);
  box-shadow: var(--shadow-lg);
  max-width: 920px;
  width: 100%;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.modal-head {
  padding: 16px 20px;
  border-bottom: 1px solid var(--line);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.modal-body { flex: 1; overflow: auto; padding: 20px; }
.modal-foot {
  padding: 14px 20px;
  border-top: 1px solid var(--line);
  display: flex;
  gap: 8px;
  justify-content: flex-end;
}

/* Generate modal */
.gen-timeline {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin: 20px 0;
}
.gen-step {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 14px;
  background: var(--bg);
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  font-size: 13px;
  transition: all 0.2s;
}
.gen-step.done { background: var(--green-wash); border-color: var(--green); }
.gen-step.active { background: var(--accent-wash); border-color: var(--accent); }
.gen-step-icon {
  width: 20px; height: 20px;
  border-radius: 50%;
  display: grid; place-items: center;
  background: var(--bg-sunken);
  color: var(--ink-3);
  font-family: var(--font-mono);
  font-size: 10px;
}
.gen-step.done .gen-step-icon { background: var(--green); color: white; }
.gen-step.active .gen-step-icon {
  background: var(--accent); color: white;
  animation: pulse 1s infinite;
}
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.1); } }
.gen-step-meta { margin-left: auto; font-family: var(--font-mono); font-size: 11px; color: var(--ink-3); }

/* Utilities */
.util-row {
  display: grid;
  grid-template-columns: 1fr 120px 110px 110px 80px;
  gap: 12px;
  align-items: center;
  padding: 10px 14px;
  border-bottom: 1px solid var(--line);
  font-size: 13px;
}
.util-row:last-child { border-bottom: 0; }
.util-row .util-name { font-weight: 500; }
.util-row .util-portal { font-family: var(--font-mono); font-size: 11px; color: var(--ink-3); }
.util-date { font-family: var(--font-mono); font-size: 11px; color: var(--ink-2); }
.util-date.empty { color: var(--ink-3); }

/* Treatment chooser */
.treatment-rec {
  background: var(--slate-wash);
  border: 1px solid var(--slate);
  border-radius: var(--radius-sm);
  padding: 14px 16px;
  margin-top: 12px;
  font-size: 13px;
  color: var(--ink);
}
.treatment-rec strong { color: var(--slate); }
.treatment-rec .label { font-family: var(--font-mono); font-size: 10px; color: var(--slate); text-transform: uppercase; letter-spacing: 0.06em; display: block; margin-bottom: 4px; }

/* Checklist */
.checklist { display: flex; flex-direction: column; gap: 6px; }
.check-item {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 10px;
  border-radius: var(--radius-sm);
  font-size: 13px;
  cursor: pointer;
}
.check-item:hover { background: var(--bg-sunken); }
.check-item .box {
  width: 16px; height: 16px;
  border: 1.5px solid var(--line-strong);
  border-radius: 3px;
  display: grid; place-items: center;
  flex-shrink: 0;
}
.check-item.done .box {
  background: var(--ink);
  border-color: var(--ink);
  color: var(--bg);
}
.check-item.done { color: var(--ink-3); text-decoration: line-through; }

/* Tweaks panel */
.tweaks-panel {
  position: fixed;
  bottom: 20px;
  right: 20px;
  width: 280px;
  background: var(--bg-elev);
  border: 1px solid var(--line-strong);
  border-radius: var(--radius);
  box-shadow: var(--shadow-lg);
  z-index: 50;
  font-size: 13px;
}
.tweaks-head {
  padding: 12px 14px;
  border-bottom: 1px solid var(--line);
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-weight: 600;
  font-size: 12px;
}
.tweaks-body { padding: 14px; display: flex; flex-direction: column; gap: 14px; }
.tweak { display: flex; flex-direction: column; gap: 6px; }
.tweak-label {
  font-family: var(--font-mono);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--ink-3);
}
.tweak-seg {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: 1fr;
  gap: 2px;
  padding: 2px;
  background: var(--bg-sunken);
  border-radius: var(--radius-sm);
}
.tweak-seg button {
  border: 0;
  background: transparent;
  padding: 6px 8px;
  font: inherit;
  font-size: 11px;
  border-radius: 3px;
  cursor: pointer;
  color: var(--ink-2);
}
.tweak-seg button.active {
  background: var(--bg);
  color: var(--ink);
  font-weight: 500;
  box-shadow: var(--shadow-sm);
}

/* Dense mode */
body.dense table.schemes td { padding: 8px 14px; }
body.dense .form-section { padding: 14px; }
body.dense .stat { padding: 10px 14px; }

/* Aesthetic: soft */
body.soft {
  --radius: 12px;
  --radius-sm: 8px;
  --bg: oklch(0.985 0.008 60);
  --bg-sunken: oklch(0.96 0.01 60);
}

/* Aesthetic: mono (less color) */
body.mono-aesthetic {
  --accent: oklch(0.32 0.01 60);
  --accent-ink: oklch(0.22 0.01 60);
  --accent-wash: oklch(0.94 0.003 60);
}

/* empty state */
.empty {
  padding: 40px;
  text-align: center;
  color: var(--ink-3);
  font-size: 13px;
}

/* =========================================
   Master Workbook
   ========================================= */
.master-workbook {
  background: var(--bg-elev);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  overflow: hidden;
}
.mwb-head {
  padding: 16px 20px;
  border-bottom: 1px solid var(--line);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16px;
  background: var(--bg-sunken);
}
.mwb-legend {
  padding: 10px 20px;
  border-bottom: 1px solid var(--line);
  display: flex;
  gap: 20px;
  font-size: 11px;
  color: var(--ink-3);
  font-family: var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.mwb-legend span { display: inline-flex; align-items: center; gap: 6px; }
.swatch {
  width: 12px; height: 12px; border-radius: 2px;
  border: 1px solid var(--line-strong);
}
.swatch.input { background: oklch(0.97 0.06 95); border-color: oklch(0.78 0.12 95); }
.swatch.calc { background: var(--bg-sunken); border-color: var(--line-strong); }
.swatch.link { background: var(--accent-wash); border-color: var(--accent); }
.mwb-section { border-bottom: 1px solid var(--line); }
.mwb-section:last-child { border-bottom: 0; }
.mwb-section-head {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 20px;
  background: var(--bg-elev);
  border-bottom: 1px solid var(--line);
  font-weight: 600;
  font-size: 13px;
  position: sticky;
  top: 0;
  z-index: 2;
}
.mwb-section-num {
  font-family: var(--font-mono);
  font-size: 11px;
  background: var(--ink);
  color: var(--bg);
  width: 22px; height: 22px;
  display: grid; place-items: center;
  border-radius: 3px;
  font-weight: 600;
}
.mwb-grid { display: flex; flex-direction: column; }
.mwb-row {
  display: grid;
  grid-template-columns: 180px 1fr 2fr;
  align-items: center;
  border-bottom: 1px solid var(--line);
  min-height: 38px;
}
.mwb-row:last-child { border-bottom: 0; }
.mwb-row.header {
  background: var(--bg-sunken);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--ink-3);
  min-height: 28px;
}
.mwb-row.header > div { padding: 6px 14px !important; font-family: var(--font-mono); }
.mwb-key {
  padding: 8px 14px;
  font-size: 11px;
  color: var(--ink-3);
  border-right: 1px solid var(--line);
  background: var(--bg-sunken);
  height: 100%;
  display: flex;
  align-items: center;
}
.mwb-label {
  padding: 8px 14px;
  font-size: 12px;
  color: var(--ink-2);
  border-right: 1px solid var(--line);
}
.mwb-val {
  padding: 4px 8px;
}
.mwb-val input, .mwb-val select {
  width: 100%;
  background: oklch(0.99 0.02 95);
  border: 1px solid transparent;
  font: inherit;
  font-size: 13px;
  padding: 6px 8px;
  border-radius: 3px;
  color: var(--ink);
}
.mwb-val input.mono { font-family: var(--font-mono); }
.mwb-val input:hover, .mwb-val select:hover { border-color: var(--line-strong); }
.mwb-val input:focus, .mwb-val select:focus {
  outline: none;
  background: white;
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-wash);
}
.mwb-row.calc .mwb-val { background: var(--bg-sunken); }
.calc-val {
  display: flex !important;
  align-items: center;
  gap: 8px;
  padding: 8px 14px !important;
  font-size: 13px;
  color: var(--ink);
}
.calc-badge {
  font-family: var(--font-mono);
  font-size: 9px;
  background: var(--ink);
  color: var(--bg);
  padding: 1px 5px;
  border-radius: 2px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.mwb-foot {
  padding: 14px 20px;
  background: var(--bg-sunken);
  border-top: 1px solid var(--line);
  font-size: 12px;
}

/* =========================================
   Road Space Request Form preview
   ========================================= */
.rsr-modal {
  max-width: 1240px;
  width: 100%;
  height: 92vh;
  max-height: 92vh;
}
.rsr-body {
  flex: 1;
  display: grid;
  grid-template-columns: 1fr 320px;
  overflow: hidden;
  min-height: 0;
}
.rsr-preview-pane {
  background: oklch(0.94 0.005 80);
  overflow: auto;
  padding: 24px;
}
.rsr-side {
  border-left: 1px solid var(--line);
  padding: 16px 18px;
  overflow: auto;
  background: var(--bg-elev);
}
.rsr-side-title {
  font-size: 11px;
  color: var(--ink-3);
  font-family: var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 10px;
}
.rsr-bind-list { display: flex; flex-direction: column; gap: 2px; }
.rsr-bind {
  padding: 6px 8px;
  border-radius: 3px;
  cursor: default;
  border: 1px solid transparent;
  font-size: 12px;
}
.rsr-bind:hover { background: var(--accent-wash); border-color: var(--accent); }
.rsr-bind.missing { opacity: 0.7; }
.rsr-bind.missing .rsr-bind-val { color: var(--amber); }
.rsr-bind-key { font-size: 10px; color: var(--ink-3); }
.rsr-bind-val {
  font-size: 12px;
  color: var(--ink);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.rsr-doc {
  max-width: 760px;
  margin: 0 auto;
  font-family: Arial, sans-serif;
}
.rsr-page {
  background: white;
  box-shadow: 0 2px 12px oklch(0 0 0 / 0.12);
  padding: 40px 48px;
  color: #1a1a1a;
  font-size: 12px;
  line-height: 1.45;
  min-height: 1000px;
}
.rsr-header { margin-bottom: 18px; }
.rsr-title-bar {
  background: #f2f2f2;
  border: 1px solid #999;
  padding: 10px 14px;
  text-align: center;
}
.rsr-title {
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 0.02em;
}
.rsr-sub {
  font-size: 11px;
  color: #333;
  font-style: italic;
  margin-top: 2px;
}
.rsr-section-title {
  font-size: 13px;
  font-weight: 700;
  background: #1f4e79;
  color: white;
  padding: 6px 10px;
  margin: 18px 0 6px;
}
.rsr-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 11px;
}
.rsr-table td {
  border: 1px solid #999;
  padding: 6px 10px;
  vertical-align: top;
}
.rsr-th {
  background: #f2f2f2;
  font-weight: 600;
  width: 34%;
  color: #111;
}
.bound {
  background: oklch(0.94 0.08 95);
  padding: 1px 4px;
  border-radius: 2px;
  border-bottom: 1px dashed oklch(0.6 0.14 75);
  color: #1f4e79;
  font-weight: 500;
  transition: background 0.15s;
}
.bound.hover {
  background: var(--accent);
  color: white;
  border-bottom-color: var(--accent);
}
.rsr-image-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 10px;
}
.rsr-image {
  border: 1px solid #999;
  background: #fafafa;
}
.rsr-image-label {
  background: #e7e7e7;
  font-size: 10px;
  font-weight: 700;
  padding: 4px 8px;
  border-bottom: 1px solid #999;
}
.rsr-image-body {
  padding: 40px 14px;
  text-align: center;
  font-size: 11px;
  color: #999;
  font-style: italic;
  min-height: 90px;
}
.rsr-notes {
  background: #fafafa;
  border: 1px solid #ddd;
  padding: 10px 14px;
  font-size: 11px;
  margin-top: 12px;
  line-height: 1.7;
}












/* =========================================
   PCI / CPP (FM701-10A) — docx-preview host
   ========================================= */
.pci-doc-host {
  max-width: 880px;
  margin: 0 auto;
  background: transparent;
}
.pci-docx-mount .docx-wrapper {
  background: transparent;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.pci-docx-mount .docx-wrapper > section.docx {
  box-shadow: 0 2px 12px oklch(0 0 0 / 0.12);
  margin-bottom: 20px;
}

/* Force left-alignment on body content — the docx has stray centering that the
   user confirmed should be left-aligned (hazards table cells, Additional info
   section etc). Preserve centering ONLY on the title band and section headers. */
.pci-docx-mount table td p,
.pci-docx-mount table td ul,
.pci-docx-mount table td ol,
.pci-docx-mount table td li {
  text-align: left !important;
}
/* Keep the title cell (first row of first table) centered-ish; its original
   layout is left-aligned too so this rule is safe. */

.pci-loading {
  text-align: center;
  padding: 40px;
  color: var(--ink-3);
  font-size: 13px;
}
.pci-loading.err { color: var(--red); }

/* Injected master-workbook value — yellow highlight */
.pci-bound {
  background: #fff59d;
  padding: 0 3px;
  font-weight: 600;
}
.pci-bound.hover {
  outline: 2px solid var(--accent);
  outline-offset: 1px;
  background: oklch(0.88 0.16 85);
}
.pci-missing {
  color: #a07000;
  font-family: var(--font-mono);
  font-size: 90%;
  background: #fff3c4;
}


/* Letter recipient picker */
.letter-recip-list {
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.letter-recip {
  text-align: left;
  background: var(--bg-elev);
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  padding: 7px 10px;
  cursor: pointer;
  font-family: inherit;
  font-size: 12px;
  color: var(--ink-1);
  transition: background 80ms;
}
.letter-recip:hover { background: var(--bg-sunken); }
.letter-recip.active {
  background: var(--accent-wash, oklch(0.95 0.04 260));
  border-color: var(--accent);
}
.letter-recip-addr { font-weight: 500; font-size: 12px; }
.letter-recip-meta { font-size: 10px; color: var(--ink-3); margin-top: 2px; font-family: var(--font-mono); }
